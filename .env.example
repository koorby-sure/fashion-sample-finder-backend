# For real visual search via SerpApi Google Lens API.
# Leave empty for demo mode search results.
SERPAPI_API_KEY=your_serpapi_key_here

# Render normally provides this automatically as RENDER_EXTERNAL_URL.
# You can still set it manually if needed, for example:
# PUBLIC_BASE_URL=https://your-backend-name.onrender.com
PUBLIC_BASE_URL=

# Set to true to test backend without SerpApi.
DEMO_MODE=false

# For testing: *
# For production: https://your-github-username.github.io
ALLOWED_ORIGINS=*

PORT=3000
